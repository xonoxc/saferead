{
  "expo": {
    "name": "saferead",
    "slug": "saferead",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "com.saferead.app",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "backgroundColor": "#000000"
    },
    "experiments": {
      "reactCompiler": true,
      "typedRoutes": true
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.saferead.andro",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-audio",
      "expo-build-properties"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9daabdc9-376e-44c2-80e9-54a51c589dbe"
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "pan",
      "package": "com.saferead.android",
      "edgeToEdgeEnabled": false
    }
  }
}
